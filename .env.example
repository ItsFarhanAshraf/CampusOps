# Copy to .env and adjust. Optional: omit POSTGRES_* to use SQLite.
#
# URL form: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# maps to POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_HOST, POSTGRES_PORT, POSTGRES_DB.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — set POSTGRES_DB to enable; leave blank for SQLite.
POSTGRES_DB=campusops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
